meta {
  name: Update My Settings
  type: http
  seq: 16
}

put {
  url: {{baseUrl}}/api/v1/me/settings
  body: json
  auth: none
}

headers {
  Cookie: session={{sessionToken}}
}

body:json {
  {
    "timezone": "Europe/Berlin",
    "reminder_lead_days": [28, 14, 7, 1],
    "weekly_digest_enabled": false,
    "weekly_digest_day": 1,
    "weekly_digest_hour": 8,
    "weekly_digest_horizon_weeks": 6
  }
}
