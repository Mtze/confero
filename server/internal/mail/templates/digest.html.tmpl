<!DOCTYPE html>
<html>
<head><meta charset="utf-8"></head>
<body style="font-family:sans-serif;max-width:600px;margin:0 auto;padding:24px">
<p>Hello <strong>{{.UserName}}</strong>,</p>
<p>Your Confero weekly digest for the week starting <strong>{{formatDate .WeekStart}}</strong>:</p>
{{if .Items}}
<ul>
{{- range .Items}}
  <li><strong>{{.ConferenceName}} ({{.ConferenceAcronym}})</strong> - {{.DeadlineKind}} deadline on {{formatDate .DeadlineDate}}</li>
{{- end}}
</ul>
{{else}}
<p>No upcoming deadlines this week.</p>
{{end}}
<p style="color:#666;font-size:0.85em">- Confero</p>
</body>
</html>
